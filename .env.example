# Copy this file to ".env" and paste your real key. NEVER commit ".env".
#   cp .env.example .env
#
DEEPL_API_KEY=your_deepl_api_key_here

# Skimlinks affiliate site id (format: <publisherId>X<siteId>, e.g. 304859X1793048).
# Leave unset until the Skimlinks account is approved -> /go links stay raw Buyee URLs.
# On the live site, set this as an env var on Render (not committed).
SKIMLINKS_ID=
